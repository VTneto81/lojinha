{
  "name": "Order",
  "type": "object",
  "properties": {
    "customer_name": {
      "type": "string"
    },
    "customer_email": {
      "type": "string"
    },
    "customer_phone": {
      "type": "string"
    },
    "customer_cpf": {
      "type": "string"
    },
    "customer_address": {
      "type": "string"
    },
    "customer_city": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "total": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "novo",
        "em_contato",
        "confirmado",
        "enviado",
        "concluido",
        "cancelado"
      ],
      "default": "novo"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "customer_name",
    "customer_phone"
  ]
}